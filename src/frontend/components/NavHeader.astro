---
interface Props {
  current?: "ingest" | "articles" | "notebook";
}

const { current } = Astro.props as Props;

const items = [
  { href: "/", label: "Ingest", key: "ingest" as const },
  { href: "/articles", label: "Articles", key: "articles" as const },
  { href: "/notebook", label: "Notebook", key: "notebook" as const },
];

const apiLinks = [
  { href: "/openapi.json", label: "OpenAPI" },
  { href: "/swagger", label: "Swagger" },
  { href: "/scalar", label: "Scalar" },
];
---

<header class="border-border bg-background sticky top-0 z-30 border-b">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-3">
    <a href="/" class="text-base font-semibold tracking-tight">The Archive</a>
    <div class="flex items-center gap-4">
      <nav class="flex items-center gap-1">
        {items.map((item) => {
          const active = current === item.key;
          return (
            <a
              href={item.href}
              class={`inline-flex h-9 items-center justify-center rounded-md px-4 text-sm font-medium transition-colors ${
                active
                  ? "bg-secondary text-secondary-foreground"
                  : "text-muted-foreground hover:bg-accent hover:text-accent-foreground"
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
      <span class="bg-border hidden h-5 w-px sm:block" />
      <nav class="hidden items-center gap-1 sm:flex">
        {apiLinks.map((link) => (
          <a
            href={link.href}
            class="text-muted-foreground hover:text-foreground inline-flex h-7 items-center rounded px-2 text-xs font-medium transition-colors"
          >
            {link.label}
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-3 w-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

