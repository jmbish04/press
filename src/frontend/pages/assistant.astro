---
import '../styles/global.css';
import { AssistantChat } from '../components/AssistantChat.tsx';
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Assistant | Monolith Archive</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased flex flex-col">
    <header class="border-b border-border bg-card sticky top-0 z-50">
      <div class="max-w-[1800px] mx-auto px-6 py-4 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold uppercase tracking-widest text-foreground">The Monolith</h1>
          <p class="text-muted-foreground text-[10px] uppercase tracking-wider">Archive & RAG Engine</p>
        </div>
        <nav class="flex gap-4">
          <a href="/" class="text-sm uppercase tracking-wider hover:text-primary pb-1">Archive</a>
          <a href="/ingest" class="text-sm uppercase tracking-wider hover:text-primary pb-1">Ingest</a>
          <a href="/assistant" class="text-sm uppercase tracking-wider hover:text-primary border-b-2 border-primary pb-1">Assistant</a>
        </nav>
      </div>
    </header>

    <main class="flex-1 flex flex-col max-w-[1800px] w-full mx-auto px-6 py-8">
      <div class="mb-6">
        <h2 class="text-3xl font-bold uppercase tracking-widest">AI Assistant</h2>
        <p class="text-muted-foreground text-xs uppercase tracking-wider mt-1">
          Semantic search powered by Vectorize and Workers AI
        </p>
      </div>

      <div class="flex-1 border rounded-none bg-card shadow-lg overflow-hidden flex flex-col">
        <AssistantChat client:load />
      </div>
    </main>

    <footer class="border-t border-border py-6 text-center text-xs uppercase tracking-wider text-muted-foreground">
      <p>Powered by Cloudflare Workers, D1, Vectorize & Workers AI</p>
    </footer>
  </body>
</html>
