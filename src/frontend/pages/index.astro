---
import "../styles/global.css";
import { Dashboard } from "../components/Dashboard.tsx";
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>The Archive</title>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <main class="mx-auto max-w-7xl space-y-8 p-6 lg:p-10">
      <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h1 class="text-3xl font-bold tracking-tight">The Archive</h1>
          <p class="text-muted-foreground mt-1 text-sm">Automated ingestion and RAG over your saved articles.</p>
        </div>
        <nav class="flex gap-2">
          <a
            href="/articles"
            class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex h-9 items-center justify-center rounded-md border px-4 text-sm font-medium shadow-sm transition-colors"
          >
            Articles
          </a>
          <a
            href="/notebook"
            class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex h-9 items-center justify-center rounded-md border px-4 text-sm font-medium shadow-sm transition-colors"
          >
            Notebook
          </a>
        </nav>
      </header>
      <Dashboard client:load />
    </main>
  </body>
</html>
