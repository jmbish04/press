---
import "../styles/global.css";
import NavHeader from "../components/NavHeader.astro";
import { IngestQueue } from "../components/IngestQueue";
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Ingest · The Archive</title>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <NavHeader current="ingest" />
    <main class="mx-auto max-w-7xl space-y-8 p-6 lg:p-10">
      <header class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Ingest URLs</h1>
        <p class="text-muted-foreground text-sm">
          Paste a block of URLs, review the parsed queue, then process — live progress streams
          back over WebSocket.
        </p>
      </header>
      <IngestQueue client:load />
    </main>
  </body>
</html>
