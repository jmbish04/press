{
  "name": "press",
  "version": "26.02.24",
  "description": "The template helps you build apps with Astro, Tailwind CSS, and shadcn/ui.",
  "license": "MIT",
  "author": {
    "name": "126colby",
    "url": "https://github.com/126colby"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/126colby/core-template-cfw-assets-astro-shadcn"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate && node scripts/post-generate-migrations.js",
    "migrate:local": "pnpm run db:generate && npx wrangler d1 migrations apply DB --local",
    "migrate:remote": "pnpm run db:generate && npx wrangler d1 migrations apply DB --remote",
    "deploy": "pnpm run build && cp .assetsignore dist/.assetsignore && pnpm run migrate:remote && npx wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@assistant-ui/react": "^0.14.7",
    "@assistant-ui/react-ai-sdk": "^1.3.26",
    "@assistant-ui/react-markdown": "^0.14.0",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@base-ui/react": "^1.4.1",
    "@cloudflare/ai-chat": "latest",
    "@cloudflare/puppeteer": "^0.0.14",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/swagger-ui": "^0.3.0",
    "@hono/zod-openapi": "^0.14.0",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.5.0",
    "@tailwindcss/vite": "^4.2.4",
    "@zumer/snapdom": "^2.12.0",
    "agents": "^0.13.0",
    "ai": "^6.0.168",
    "astro": "^5.18.1",
    "class-variance-authority": "^0.7.1",
    "clipboard-polyfill": "^4.1.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "lucide-react": "^0.575.0",
    "mind-elixir": "^5.12.1",
    "platejs": "^53.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.0",
    "slate": "^0.124.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.11",
    "workers-ai-provider": "^3.1.14",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "file:./tools/stub-workers-types",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.24.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.85.0"
  },
  "pnpm": {
    "overrides": {
      "@cloudflare/workers-types": "file:./tools/stub-workers-types"
    }
  }
}
